chmod 600 /home/joaquim/.ssh/id_rsa
chown -R joaquim:joaquim /home/joaquim/.ssh
su - joaquim -c "ssh-keygen -y -f /home/joaquim/.ssh/id_rsa > /home/joaquim/.ssh/id_rsa.pub"

# Evita prompt interativo de host key nos testes do roteiro
cat > /home/joaquim/.ssh/config <<'EOF'
Host *
	StrictHostKeyChecking no
	UserKnownHostsFile /dev/null
EOF
chmod 600 /home/joaquim/.ssh/config
chown joaquim:joaquim /home/joaquim/.ssh/config
