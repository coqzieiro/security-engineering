chmod 600 /etc/openvpn/minhavpn.key

# Configuracao da VPN matriz (A) -> filial (B)
cat > /etc/openvpn/matriz.conf <<'EOF'
remote 202.135.187.10
dev tun
ifconfig 10.0.0.1 10.0.0.2
cd /etc/openvpn
secret minhavpn.key
port 5000
user root
group root
comp-lzo
ping 15
verb 3
daemon
EOF

openvpn --config /etc/openvpn/matriz.conf

# Rota para chegar na rede da empresa B pelo tunel VPN
route add -net 192.168.2.0/24 gw 10.0.0.2